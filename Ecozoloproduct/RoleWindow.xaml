<Window x:Class="WpfApp2.RoleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление ролями" 
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F5F0E8">

    <Window.Resources>
        <!-- Цвета темы (бежевый, зелёный) -->
        <SolidColorBrush x:Key="BeigeColor" Color="#F5F0E8"/>
        <SolidColorBrush x:Key="DarkBeigeColor" Color="#E8DCC8"/>
        <SolidColorBrush x:Key="LightBeigeColor" Color="#FAF6EF"/>
        <SolidColorBrush x:Key="GreenColor" Color="#5A8F4C"/>
        <SolidColorBrush x:Key="DarkGreenColor" Color="#3D6B2E"/>
        <SolidColorBrush x:Key="LightGreenColor" Color="#7BAF6A"/>
        <SolidColorBrush x:Key="WhiteColor" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextColor" Color="#4A3728"/>

        <!-- Стиль для кнопок -->
        <Style x:Key="GreenButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource GreenColor}"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteColor}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource LightGreenColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource DarkGreenColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BeigeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource DarkBeigeColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource GreenColor}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                BorderThickness="1"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BeigeColor}"/>
                                <Setter Property="Foreground" Value="{StaticResource DarkGreenColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для текстовых полей -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource WhiteColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DarkBeigeColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{StaticResource GreenColor}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Стиль для DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource WhiteColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource BeigeColor}"/>
            <Setter Property="RowBackground" Value="{StaticResource WhiteColor}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="BorderBrush" Value="{StaticResource DarkBeigeColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource GreenColor}"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteColor}"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{StaticResource LightGreenColor}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="5,0,10,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinWidth" Value="100"/>
        </Style>

        <Style x:Key="PageHeaderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource GreenColor}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20" Background="{StaticResource BeigeColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Style="{StaticResource PageHeaderStyle}">
            <Grid>
                <TextBlock Text="👥 УПРАВЛЕНИЕ РОЛЯМИ 👥" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource WhiteColor}" 
                           HorizontalAlignment="Center" 
                           Margin="20,15"
                           FontFamily="Segoe UI"/>
            </Grid>
        </Border>

        <!-- Таблица данных -->
        <DataGrid x:Name="RolesDataGrid" Grid.Row="1" 
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False" 
                  CanUserDeleteRows="False"
                  SelectionMode="Single" 
                  SelectionUnit="FullRow"
                  Margin="0,10,0,10"
                  SelectionChanged="RolesDataGrid_SelectionChanged"
                  AlternatingRowBackground="{StaticResource BeigeColor}"
                  RowBackground="{StaticResource WhiteColor}"
                  BorderBrush="{StaticResource DarkBeigeColor}"
                  BorderThickness="1"
                  FontSize="13"
                  FontFamily="Segoe UI"
                  HorizontalGridLinesBrush="{StaticResource DarkBeigeColor}"
                  VerticalGridLinesBrush="Transparent">

            <DataGrid.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#5A8F4C" Opacity="0.2"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#3D6B2E"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#5A8F4C" Opacity="0.1"/>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <!-- ID роли - фиксированная ширина, текст по центру -->
                <DataGridTextColumn Header="ID роли" Binding="{Binding RoleId}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Foreground" Value="{StaticResource GreenColor}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Название роли - занимает всё оставшееся пространство, текст по центру -->
                <DataGridTextColumn Header="Название роли" Binding="{Binding RoleName}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Панель добавления/редактирования -->
        <Border Grid.Row="2" Background="{StaticResource WhiteColor}" 
                BorderBrush="{StaticResource DarkBeigeColor}" 
                BorderThickness="1" 
                CornerRadius="8" Margin="0,5,0,0">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок панели -->
                <Border Grid.Row="0" Background="{StaticResource LightBeigeColor}" CornerRadius="5" Padding="12" Margin="0,0,0,15">
                    <TextBlock Text="📝 Добавление / Редактирование роли" 
                               FontSize="15" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource GreenColor}"
                               FontFamily="Segoe UI"/>
                </Border>

                <!-- Панель ввода данных - строка, а не столбец -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <!-- Название роли -->
                    <TextBlock Text="Название роли:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                    <TextBox x:Name="RoleNameTextBox" Width="250" Height="38" 
                             VerticalAlignment="Center"
                             ToolTip="Введите название роли"/>

                    <!-- Кнопки -->
                    <Button x:Name="AddButton" Content="➕ Добавить" Style="{StaticResource GreenButtonStyle}" Click="AddButton_Click"/>
                    <Button x:Name="UpdateButton" Content="✏️ Обновить" Style="{StaticResource GreenButtonStyle}" Click="UpdateButton_Click"/>
                    <Button x:Name="DeleteButton" Content="🗑 Удалить" Style="{StaticResource BeigeButtonStyle}" Click="DeleteButton_Click"/>
                    <Button x:Name="RefreshButton" Content="🔄 Обновить список" Style="{StaticResource GreenButtonStyle}" Click="RefreshButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>