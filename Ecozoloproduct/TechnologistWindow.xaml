<Window x:Class="WpfApp2.TechnologistWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Панель технолога" 
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F5F0E8">

    <Grid Margin="20" Background="#F5F0E8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#5A8F4C" CornerRadius="8" Margin="0,0,0,15">
            <TextBlock Text="🔬 ПАНЕЛЬ ТЕХНОЛОГА 🔬" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="White" 
                       HorizontalAlignment="Center" 
                       Margin="20,15"
                       FontFamily="Segoe UI"/>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20" Margin="0,5,0,0"
                BorderBrush="#E8DCC8" BorderThickness="1">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="WelcomeTextBlock" Text="Добро пожаловать!" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="#4A3728"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>
                <TextBlock Text="Вы можете анализировать технологические процессы и качество продукции" 
                           FontSize="14" 
                           Foreground="#8B9A6E"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"/>
                <Button x:Name="ExitButton" Content="🚪 Выход" Width="150" Height="40" Margin="0,20,0,0"
                        Background="#E8DCC8" Foreground="#4A3728" FontWeight="Bold" Click="ExitButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>