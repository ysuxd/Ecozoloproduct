<Window x:Class="WpfApp2.ShiftDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Детали работы оборудования" 
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F5F0E8">

    <Window.Resources>
        <SolidColorBrush x:Key="BeigeColor" Color="#F5F0E8"/>
        <SolidColorBrush x:Key="DarkBeigeColor" Color="#E8DCC8"/>
        <SolidColorBrush x:Key="LightBeigeColor" Color="#FAF6EF"/>
        <SolidColorBrush x:Key="GreenColor" Color="#5A8F4C"/>
        <SolidColorBrush x:Key="DarkGreenColor" Color="#3D6B2E"/>
        <SolidColorBrush x:Key="LightGreenColor" Color="#7BAF6A"/>
        <SolidColorBrush x:Key="WhiteColor" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextColor" Color="#4A3728"/>

        <Style x:Key="GreenButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource GreenColor}"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteColor}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource LightGreenColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource DarkGreenColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BeigeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource DarkBeigeColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource GreenColor}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                BorderThickness="1"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BeigeColor}"/>
                                <Setter Property="Foreground" Value="{StaticResource DarkGreenColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ExitButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E74C3C"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteColor}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C0392B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#A93226"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource WhiteColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DarkBeigeColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{StaticResource GreenColor}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource WhiteColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DarkBeigeColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource WhiteColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource BeigeColor}"/>
            <Setter Property="RowBackground" Value="{StaticResource WhiteColor}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="BorderBrush" Value="{StaticResource DarkBeigeColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource GreenColor}"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteColor}"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{StaticResource LightGreenColor}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="5,0,5,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="InfoLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource GreenColor}"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="PageHeaderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource GreenColor}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20" Background="{StaticResource BeigeColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Style="{StaticResource PageHeaderStyle}">
            <TextBlock x:Name="TitleTextBlock" Text="⚙️ ДЕТАЛИ РАБОТЫ ОБОРУДОВАНИЯ ⚙️" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="{StaticResource WhiteColor}" 
                       HorizontalAlignment="Center" 
                       Margin="20,15"
                       FontFamily="Segoe UI"/>
        </Border>

        <!-- Информация о смене -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15"
                BorderBrush="{StaticResource DarkBeigeColor}" BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="📅 Смена:" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock x:Name="ShiftInfoTextBlock" FontSize="14" Foreground="{StaticResource DarkGreenColor}" 
                           FontWeight="SemiBold" Margin="10,0,20,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Таблица данных -->
        <DataGrid x:Name="ShiftDetailsDataGrid" Grid.Row="2" 
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False" 
                  CanUserDeleteRows="False"
                  SelectionMode="Single" 
                  SelectionUnit="FullRow"
                  Margin="0,10,0,10"
                  SelectionChanged="ShiftDetailsDataGrid_SelectionChanged"
                  AlternatingRowBackground="{StaticResource BeigeColor}"
                  RowBackground="{StaticResource WhiteColor}"
                  BorderBrush="{StaticResource DarkBeigeColor}"
                  BorderThickness="1">

            <DataGrid.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#5A8F4C" Opacity="0.2"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#3D6B2E"/>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Оборудование" Binding="{Binding EquipmentName}" Width="2*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Время работы" Binding="{Binding EquipmentWorkTimeDisplay}" Width="1.5*"/>

                <DataGridTextColumn Header="Количество продукции (шт)" Binding="{Binding ProductionQuantity}" Width="1.5*"/>

                <DataGridTextColumn Header="Качественная продукция (шт)" Binding="{Binding QualityProductionQuantity}" Width="1.5*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Панель добавления/редактирования -->
        <Border Grid.Row="3" Background="{StaticResource WhiteColor}" 
                BorderBrush="{StaticResource DarkBeigeColor}" 
                BorderThickness="1" 
                CornerRadius="8" Margin="0,5,0,0">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource LightBeigeColor}" CornerRadius="5" Padding="12" Margin="0,0,0,15">
                    <TextBlock Text="📝 Добавление / Редактирование" 
                               FontSize="15" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource GreenColor}"
                               FontFamily="Segoe UI"/>
                </Border>

                <!-- Панель ввода данных - без поля "Время работы" -->
                <WrapPanel Grid.Row="1" Margin="0,5,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Оборудование:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                    <ComboBox x:Name="EquipmentComboBox" Width="180" Height="38" 
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              Margin="5,5,15,5"/>

                    <TextBlock Text="Продукция (шт):" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                    <TextBox x:Name="ProductionQuantityTextBox" Width="130" Height="38" 
                             ToolTip="Количество произведенной продукции"
                             Margin="5,5,15,5"/>

                    <TextBlock Text="Качество (шт):" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                    <TextBox x:Name="QualityProductionQuantityTextBox" Width="130" Height="38" 
                             ToolTip="Количество качественной продукции"
                             Margin="5,5,15,5"/>

                    <Button x:Name="AddButton" Content="➕ Добавить" Style="{StaticResource GreenButtonStyle}" Click="AddButton_Click"/>
                    <Button x:Name="UpdateButton" Content="✏️ Обновить" Style="{StaticResource GreenButtonStyle}" Click="UpdateButton_Click"/>
                    <Button x:Name="DeleteButton" Content="🗑 Удалить" Style="{StaticResource BeigeButtonStyle}" Click="DeleteButton_Click"/>
                    <Button x:Name="RefreshButton" Content="🔄 Обновить" Style="{StaticResource GreenButtonStyle}" Click="RefreshButton_Click"/>
                    <Button x:Name="ExitButton" Content="🚪 Выход" Style="{StaticResource ExitButtonStyle}" Click="ExitButton_Click"/>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Window>