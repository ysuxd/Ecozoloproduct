<Window x:Class="WpfApp2.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация нового пользователя" 
        Height="650" 
        Width="550"
        WindowStartupLocation="CenterOwner"
        Background="#F5F0E8"
        ResizeMode="NoResize">

    <Window.Resources>
        <SolidColorBrush x:Key="GreenColor" Color="#5A8F4C"/>
        <SolidColorBrush x:Key="DarkGreenColor" Color="#3D6B2E"/>
        <SolidColorBrush x:Key="LightGreenColor" Color="#7BAF6A"/>
        <SolidColorBrush x:Key="WhiteColor" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextColor" Color="#4A3728"/>
        <SolidColorBrush x:Key="ErrorColor" Color="#E74C3C"/>
        <SolidColorBrush x:Key="DarkBeigeColor" Color="#E8DCC8"/>
        <SolidColorBrush x:Key="LightBeigeColor" Color="#FAF6EF"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#27AE60"/>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource WhiteColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DarkBeigeColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,3,0,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource GreenColor}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource GreenColor}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource WhiteColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DarkBeigeColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,3,0,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource GreenColor}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource GreenColor}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Упрощенный стиль для ComboBox без кастомной стрелки -->
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource WhiteColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DarkBeigeColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,3,0,12"/>
        </Style>

        <Style x:Key="RegisterSubmitButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource GreenColor}"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteColor}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="12" 
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource LightGreenColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource DarkGreenColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CancelButtonStyle" TargetType="Button" BasedOn="{StaticResource RegisterSubmitButtonStyle}">
            <Setter Property="Background" Value="{StaticResource DarkBeigeColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource GreenColor}" CornerRadius="15" Margin="0,0,0,20">
            <TextBlock Text="📝 РЕГИСТРАЦИЯ НОВОГО ПОЛЬЗОВАТЕЛЯ" 
                       FontSize="16" 
                       FontWeight="Bold" 
                       Foreground="White" 
                       HorizontalAlignment="Center" 
                       Padding="20,12"
                       FontFamily="Segoe UI"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Background="White"
                    CornerRadius="15"
                    BorderBrush="{StaticResource DarkBeigeColor}"
                    BorderThickness="1"
                    Padding="25,20">

                <StackPanel>
                    <TextBlock Text="ЛОГИН" FontWeight="SemiBold" 
                               Foreground="{StaticResource TextColor}" 
                               FontSize="12"
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="LoginTextBox"/>

                    <TextBlock Text="ПАРОЛЬ" FontWeight="SemiBold" 
                               Foreground="{StaticResource TextColor}" 
                               FontSize="12"
                               Margin="0,15,0,5"/>
                    <PasswordBox x:Name="PasswordBox"/>

                    <TextBlock Text="ПОДТВЕРЖДЕНИЕ ПАРОЛЯ" FontWeight="SemiBold" 
                               Foreground="{StaticResource TextColor}" 
                               FontSize="12"
                               Margin="0,15,0,5"/>
                    <PasswordBox x:Name="ConfirmPasswordBox"/>

                    <TextBlock Text="РОЛЬ" FontWeight="SemiBold" 
                               Foreground="{StaticResource TextColor}" 
                               FontSize="12"
                               Margin="0,15,0,5"/>
                    <ComboBox x:Name="RoleComboBox" SelectedIndex="0"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25,0,10">
                        <Button x:Name="RegisterButton" Content="ЗАРЕГИСТРИРОВАТЬСЯ" 
                                Style="{StaticResource RegisterSubmitButtonStyle}" 
                                Width="200"
                                Click="RegisterButton_Click"/>
                        <Button x:Name="CancelButton" Content="ОТМЕНА" 
                                Style="{StaticResource CancelButtonStyle}" 
                                Width="120"
                                Margin="15,0,0,0"
                                Click="CancelButton_Click"/>
                    </StackPanel>

                    <TextBlock x:Name="ErrorTextBlock" 
                               Foreground="{StaticResource ErrorColor}" 
                               HorizontalAlignment="Center" 
                               FontSize="11"
                               Visibility="Collapsed"
                               Margin="0,10,0,5"/>

                    <TextBlock x:Name="SuccessTextBlock" 
                               Foreground="{StaticResource SuccessColor}" 
                               HorizontalAlignment="Center" 
                               FontSize="11"
                               Visibility="Collapsed"
                               Margin="0,10,0,5"/>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>