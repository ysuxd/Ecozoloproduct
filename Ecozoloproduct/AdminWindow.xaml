<Window x:Class="WpfApp2.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Панель администратора" 
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F5F0E8">

    <Window.Resources>
        <!-- Стиль для кнопок меню -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="220"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Background" Value="#5A8F4C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#7BAF6A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3D6B2E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для маленьких кнопок -->
        <Style x:Key="SmallMenuButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="200"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Background" Value="#5A8F4C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#7BAF6A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3D6B2E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ExitButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="150"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Background" Value="#E8DCC8"/>
            <Setter Property="Foreground" Value="#4A3728"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#5A8F4C"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                BorderThickness="1"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F5F0E8"/>
                                <Setter Property="Foreground" Value="#3D6B2E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20" Background="#F5F0E8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#5A8F4C" CornerRadius="8" Margin="0,0,0,15">
            <Grid>
                <TextBlock Text="👑 ПАНЕЛЬ АДМИНИСТРАТОРА 👑" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           HorizontalAlignment="Center" 
                           Margin="20,15"
                           FontFamily="Segoe UI"/>
            </Grid>
        </Border>

        <!-- Панель управления - Первая строка: Пользователи и роли -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10"
                BorderBrush="#E8DCC8" BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="UsersButton" Content="👥 Управление пользователями" Style="{StaticResource MenuButtonStyle}" Click="UsersButton_Click"/>
                <Button x:Name="RolesButton" Content="🔑 Управление ролями" Style="{StaticResource MenuButtonStyle}" Click="RolesButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Панель управления - Вторая строка: Справочники -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10"
                BorderBrush="#E8DCC8" BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="StatusButton" Content="📊 Управление состояниями" Style="{StaticResource MenuButtonStyle}" Click="StatusButton_Click"/>
                <Button x:Name="EquipmentButton" Content="🏭 Управление оборудованием" Style="{StaticResource MenuButtonStyle}" Click="EquipmentButton_Click"/>
                
            </StackPanel>
        </Border>

        <!-- Панель управления - Третья строка: Учет работы -->
        <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15"
                BorderBrush="#E8DCC8" BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="ShiftsButton" Content="⏰ Управление сменами" Style="{StaticResource SmallMenuButtonStyle}" Click="ShiftsButton_Click"/>
                <Button x:Name="ShiftDetailsButton" Content="📋 Детали смен" Style="{StaticResource SmallMenuButtonStyle}" Click="ShiftDetailsButton_Click"/>
                <Button x:Name="DowntimeRecordButton" Content="⚠️ Учет простоев" Style="{StaticResource SmallMenuButtonStyle}" Click="DowntimeRecordButton_Click"/>
                <Button x:Name="ExitButton" Content="🚪 Выход" Style="{StaticResource ExitButtonStyle}" Click="ExitButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Информационная панель -->
        <Border Grid.Row="4" Background="White" CornerRadius="8" Padding="20" Margin="0,5,0,0"
                BorderBrush="#E8DCC8" BorderThickness="1">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="📊 Добро пожаловать в систему управления!" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="#4A3728"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>
                <TextBlock Text="Вы можете управлять пользователями, ролями, справочниками и вести учет работы оборудования" 
                           FontSize="14" 
                           Foreground="#8B9A6E"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>