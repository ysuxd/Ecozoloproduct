<Window x:Class="WpfApp2.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Панель администратора" 
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F5F0E8">

    <Window.Resources>
        <!-- Мягкие цвета для заголовков -->
        <SolidColorBrush x:Key="HeaderGreen" Color="#7BAF6A"/>
        <SolidColorBrush x:Key="HeaderBlue" Color="#5DADE2"/>
        <SolidColorBrush x:Key="HeaderGray" Color="#A6ACAF"/>

        <!-- Стиль для кнопок внутри панели -->
        <Style x:Key="PanelButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="240"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Background" Value="#5A8F4C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="10" 
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#7BAF6A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3D6B2E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для кнопки эффективности -->
        <Style x:Key="EfficiencyButtonStyle" TargetType="Button" BasedOn="{StaticResource PanelButtonStyle}">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Width" Value="260"/>
        </Style>

        <!-- Стиль для кнопки выхода -->
        <Style x:Key="ExitButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E74C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="240"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                        CornerRadius="10" 
                        BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C0392B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#A93226"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для заголовка панели -->
        <Style x:Key="PanelHeaderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10,10,0,0"/>
            <Setter Property="Padding" Value="15,12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20" Background="#F5F0E8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок окна -->
        <Border Grid.Row="0" Background="#5A8F4C" CornerRadius="10" Margin="0,0,0,15">
            <TextBlock Text="👑 ПАНЕЛЬ АДМИНИСТРАТОРА 👑" 
                       FontSize="26" 
                       FontWeight="Bold" 
                       Foreground="White" 
                       HorizontalAlignment="Center" 
                       Padding="25,18"
                       FontFamily="Segoe UI"/>
        </Border>

        <!-- Контейнер для панелей -->
        <UniformGrid Grid.Row="1" Rows="5" Columns="1" Margin="80,15,80,15">

            <!-- Панель 1: Управление пользователями -->
            <Border Background="White" CornerRadius="10" Margin="0,10,0,10"
                    BorderBrush="#E8DCC8" BorderThickness="1">
                <StackPanel>
                    <Border Style="{StaticResource PanelHeaderStyle}" Background="#7BAF6A">
                        <TextBlock Text="👥 УПРАВЛЕНИЕ ПОЛЬЗОВАТЕЛЯМИ" 
                                   FontWeight="Bold" 
                                   Foreground="White" 
                                   FontSize="15"
                                   HorizontalAlignment="Center"/>
                    </Border>
                    <WrapPanel HorizontalAlignment="Center" Margin="20,15,20,15">
                        <Button x:Name="UsersButton" Content="👥 Пользователи" Style="{StaticResource PanelButtonStyle}" Click="UsersButton_Click"/>
                        <Button x:Name="RolesButton" Content="🔑 Роли" Style="{StaticResource PanelButtonStyle}" Click="RolesButton_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Панель 2: Справочники -->
            <Border Background="White" CornerRadius="10" Margin="0,10,0,10"
                    BorderBrush="#E8DCC8" BorderThickness="1">
                <StackPanel>
                    <Border Style="{StaticResource PanelHeaderStyle}" Background="#7BAF6A">
                        <TextBlock Text="📚 СПРАВОЧНИКИ" 
                                   FontWeight="Bold" 
                                   Foreground="White" 
                                   FontSize="15"
                                   HorizontalAlignment="Center"/>
                    </Border>
                    <WrapPanel HorizontalAlignment="Center" Margin="20,15,20,15">
                        <Button x:Name="StatusButton" Content="📊 Состояния" Style="{StaticResource PanelButtonStyle}" Click="StatusButton_Click"/>
                        <Button x:Name="EquipmentButton" Content="🏭 Оборудование" Style="{StaticResource PanelButtonStyle}" Click="EquipmentButton_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Панель 3: Учет работы -->
            <Border Background="White" CornerRadius="10" Margin="0,10,0,10"
                    BorderBrush="#E8DCC8" BorderThickness="1">
                <StackPanel>
                    <Border Style="{StaticResource PanelHeaderStyle}" Background="#7BAF6A">
                        <TextBlock Text="📝 УЧЕТ РАБОТЫ" 
                                   FontWeight="Bold" 
                                   Foreground="White" 
                                   FontSize="15"
                                   HorizontalAlignment="Center"/>
                    </Border>
                    <WrapPanel HorizontalAlignment="Center" Margin="20,15,20,15">
                        <Button x:Name="ShiftsButton" Content="⏰ Смены" Style="{StaticResource PanelButtonStyle}" Click="ShiftsButton_Click"/>
                        <Button x:Name="ShiftDetailsButton" Content="📋 Детали смен" Style="{StaticResource PanelButtonStyle}" Click="ShiftDetailsButton_Click"/>
                        <Button x:Name="DowntimeRecordButton" Content="⚠️ Простои" Style="{StaticResource PanelButtonStyle}" Click="DowntimeRecordButton_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Панель 4: Аналитика -->
            <Border Background="White" CornerRadius="10" Margin="0,10,0,10"
                    BorderBrush="#E8DCC8" BorderThickness="1">
                <StackPanel>
                    <Border Style="{StaticResource PanelHeaderStyle}" Background="#7BAF6A">
                        <TextBlock Text="📊 АНАЛИТИКА" 
                                   FontWeight="Bold" 
                                   Foreground="White" 
                                   FontSize="15"
                                   HorizontalAlignment="Center"/>
                    </Border>
                    <WrapPanel HorizontalAlignment="Center" Margin="20,15,20,15">
                        <Button x:Name="EfficiencyButton" Content="📈 Эффективность OEE" Style="{StaticResource PanelButtonStyle}" Click="EfficiencyButton_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Панель 5: Система (Выход) -->
            <Border Background="White" CornerRadius="10" Margin="0,10,0,10"
                    BorderBrush="#E8DCC8" BorderThickness="1">
                <StackPanel>
                    <Border Style="{StaticResource PanelHeaderStyle}" Background="#A6ACAF">
                        <TextBlock Text="⚙️ СИСТЕМА" 
                                   FontWeight="Bold" 
                                   Foreground="White" 
                                   FontSize="15"
                                   HorizontalAlignment="Center"/>
                    </Border>
                    <WrapPanel HorizontalAlignment="Center" Margin="20,15,20,15">
                        <Button x:Name="ExitButton" Content="🚪 Выход" Style="{StaticResource ExitButtonStyle}" Click="ExitButton_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

        </UniformGrid>
    </Grid>
</Window>