<Window x:Class="WpfApp2.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Панель администратора" 
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F5F0E8">

    <Grid Margin="20" Background="#F5F0E8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#5A8F4C" CornerRadius="8" Margin="0,0,0,15">
            <Grid>
                <TextBlock Text="👑 ПАНЕЛЬ АДМИНИСТРАТОРА 👑" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           HorizontalAlignment="Center" 
                           Margin="20,15"
                           FontFamily="Segoe UI"/>
            </Grid>
        </Border>

        <!-- Панель управления -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15"
                BorderBrush="#E8DCC8" BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="UsersButton" Content="👥 Управление пользователями" 
                        Width="220" Height="45" Margin="10" Click="UsersButton_Click"
                        Background="#5A8F4C" Foreground="White" FontWeight="Bold" Cursor="Hand"/>
                <Button x:Name="RolesButton" Content="🔑 Управление ролями" 
                        Width="220" Height="45" Margin="10" Click="RolesButton_Click"
                        Background="#5A8F4C" Foreground="White" FontWeight="Bold" Cursor="Hand"/>
                <Button x:Name="ExitButton" Content="🚪 Выход" 
                        Width="150" Height="45" Margin="10" Click="ExitButton_Click"
                        Background="#E8DCC8" Foreground="#4A3728" FontWeight="Bold" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- Информационная панель -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="20"
                BorderBrush="#E8DCC8" BorderThickness="1">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="📊 Добро пожаловать в систему управления!" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="#4A3728"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>
                <TextBlock Text="Вы можете управлять пользователями и ролями" 
                           FontSize="14" 
                           Foreground="#8B9A6E"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>