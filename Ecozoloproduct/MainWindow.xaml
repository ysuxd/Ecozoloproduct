<Window x:Class="WpfApp2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация" 
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F5F0E8"
        AllowsTransparency="False">

    <Window.Resources>
        <!-- Цвета темы -->
        <SolidColorBrush x:Key="GreenColor" Color="#5A8F4C"/>
        <SolidColorBrush x:Key="DarkGreenColor" Color="#3D6B2E"/>
        <SolidColorBrush x:Key="LightGreenColor" Color="#7BAF6A"/>
        <SolidColorBrush x:Key="WhiteColor" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextColor" Color="#4A3728"/>
        <SolidColorBrush x:Key="ErrorColor" Color="#E74C3C"/>
        <SolidColorBrush x:Key="BeigeColor" Color="#F5F0E8"/>
        <SolidColorBrush x:Key="DarkBeigeColor" Color="#E8DCC8"/>
        <SolidColorBrush x:Key="LightBeigeColor" Color="#FAF6EF"/>
        <SolidColorBrush x:Key="OliveGreenColor" Color="#8B9A6E"/>
        <SolidColorBrush x:Key="FormBeigeColor" Color="#FDF9F2"/>

        <!-- Стиль для кнопки входа -->
        <Style x:Key="LoginButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource GreenColor}"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteColor}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="10" 
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource LightGreenColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource DarkGreenColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для кнопки регистрации -->
        <Style x:Key="RegisterButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource GreenColor}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource GreenColor}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="10" 
                                BorderThickness="1"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource LightGreenColor}"/>
                                <Setter Property="Foreground" Value="{StaticResource WhiteColor}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource LightGreenColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для текстовых полей -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource WhiteColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DarkBeigeColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{StaticResource GreenColor}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Margin" Value="0,3,0,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource GreenColor}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource GreenColor}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource WhiteColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DarkBeigeColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{StaticResource GreenColor}"/>
            <Setter Property="Margin" Value="0,3,0,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource GreenColor}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource GreenColor}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для поля капчи -->
        <Style x:Key="CaptchaTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Width" Value="180"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource WhiteColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DarkBeigeColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{StaticResource GreenColor}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource GreenColor}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource GreenColor}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DropShadowEffect x:Key="CardShadow" 
                          ShadowDepth="4" 
                          Direction="270" 
                          Opacity="0.15" 
                          BlurRadius="15"/>
    </Window.Resources>

    <Grid Background="{StaticResource BeigeColor}">
        <Border Width="1100" 
                Height="680"
                HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                Background="White"
                CornerRadius="30"
                BorderBrush="{StaticResource DarkBeigeColor}"
                BorderThickness="1"
                Effect="{StaticResource CardShadow}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Height="8" Background="{StaticResource GreenColor}" 
                        CornerRadius="30,30,0,0"/>

                <Grid Grid.Row="1" Margin="50,40,50,40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ЛЕВАЯ ЧАСТЬ: Карточка авторизации -->
                    <Border Grid.Column="0" 
                            Width="460" 
                            Height="560"
                            Background="{StaticResource FormBeigeColor}"
                            CornerRadius="20"
                            BorderBrush="{StaticResource DarkBeigeColor}"
                            BorderThickness="1"
                            Margin="0,0,60,0">

                        <Grid Margin="30">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Height="3" Background="{StaticResource GreenColor}" 
                                    CornerRadius="2" Width="50" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                            <TextBlock Grid.Row="1" 
                                       Text="🔐 ДОБРО ПОЖАЛОВАТЬ" 
                                       FontSize="18" 
                                       FontWeight="Bold" 
                                       Foreground="{StaticResource GreenColor}" 
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,15"/>

                            <Border Grid.Row="2" Width="65" Height="65" 
                                    Background="{StaticResource WhiteColor}" 
                                    CornerRadius="32.5"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,10">
                                <TextBlock Text="👤" FontSize="35" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Grid.Row="3" 
                                       Text="Введите учетные данные" 
                                       FontSize="12" 
                                       Foreground="{StaticResource OliveGreenColor}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,15"/>

                            <StackPanel Grid.Row="4" Margin="0,0,0,10">
                                <TextBlock Text="ЛОГИН" FontWeight="SemiBold" 
                                           Foreground="{StaticResource TextColor}" 
                                           FontSize="11"
                                           Margin="0,0,0,3"/>
                                <TextBox x:Name="LoginTextBox"/>
                            </StackPanel>

                            <StackPanel Grid.Row="5" Margin="0,0,0,15">
                                <TextBlock Text="ПАРОЛЬ" FontWeight="SemiBold" 
                                           Foreground="{StaticResource TextColor}" 
                                           FontSize="11"
                                           Margin="0,0,0,3"/>
                                <PasswordBox x:Name="PasswordBox"/>
                            </StackPanel>

                            <!-- Капча -->
                            <StackPanel Grid.Row="6" Margin="0,0,0,15">
                                <TextBlock Text="ВВЕДИТЕ КОД С КАРТИНКИ" FontWeight="SemiBold" 
                                           Foreground="{StaticResource TextColor}" 
                                           FontSize="11"
                                           Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Блок с кодом капчи -->
                                    <Border Grid.Column="0" Width="130" Height="45" 
                                            Background="{StaticResource LightBeigeColor}"
                                            CornerRadius="10"
                                            BorderBrush="{StaticResource DarkBeigeColor}"
                                            BorderThickness="1">
                                        <TextBlock x:Name="CaptchaTextBlock" 
                                                   Text="A1B2C" 
                                                   FontSize="20" 
                                                   FontWeight="Bold"
                                                   FontFamily="Courier New"
                                                   Foreground="{StaticResource DarkGreenColor}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Кнопка обновления капчи (квадратная с иконкой) -->
                                    <Button x:Name="RefreshCaptchaButton" 
                                            Grid.Column="1"
                                            Width="45" 
                                            Height="45"
                                            Margin="10,0,10,0"
                                            Background="{StaticResource GreenColor}"
                                            Foreground="White"
                                            FontSize="20"
                                            FontWeight="Bold"
                                            Cursor="Hand"
                                            BorderThickness="0"
                                            Click="RefreshCaptchaButton_Click"
                                            ToolTip="Обновить код">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" 
                                                        CornerRadius="10" 
                                                        BorderThickness="0">
                                                    <ContentPresenter HorizontalAlignment="Center" 
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource LightGreenColor}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource DarkGreenColor}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <TextBlock Text="🔄" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>

                                    <!-- Поле ввода капчи -->
                                    <TextBox x:Name="CaptchaTextBox" 
                                             Grid.Column="2"
                                             Width="180"
                                             Height="45"
                                             HorizontalAlignment="Left"
                                             Style="{StaticResource CaptchaTextBoxStyle}"
                                             ToolTip="Введите код с картинки"/>
                                </Grid>
                            </StackPanel>

                            <!-- Кнопки -->
                            <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <Button x:Name="LoginButton" 
                                        Content="ВОЙТИ" 
                                        Style="{StaticResource LoginButtonStyle}" 
                                        Click="LoginButton_Click"/>
                                <Button x:Name="RegisterButton" 
                                        Content="РЕГИСТРАЦИЯ" 
                                        Style="{StaticResource RegisterButtonStyle}" 
                                        Margin="10,0,0,0"
                                        Click="RegisterButton_Click"/>
                            </StackPanel>

                            <TextBlock x:Name="ErrorTextBlock" Grid.Row="8" 
                                       Foreground="{StaticResource ErrorColor}" 
                                       HorizontalAlignment="Center" 
                                       FontSize="11"
                                       Visibility="Collapsed"
                                       Text="Неверный логин или пароль"
                                       Margin="0,15,0,0"/>
                        </Grid>
                    </Border>

                    <!-- ПРАВАЯ ЧАСТЬ: Описание приложения -->
                    <StackPanel Grid.Column="1" 
                                VerticalAlignment="Center">

                        <Border Width="70" Height="70" 
                                Background="{StaticResource GreenColor}" 
                                CornerRadius="18"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,15">
                            <TextBlock Text="🏭" FontSize="38" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Система учета работы оборудования" 
                                   FontSize="22" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource GreenColor}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="ООО «ЭКО-Золопродукт инвест»" 
                                   FontSize="14" 
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource DarkGreenColor}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,15"/>

                        <TextBlock Text="Автоматизированная подсистема мониторинга и анализа эффективности технологического оборудования"
                                   FontSize="13"
                                   Foreground="{StaticResource TextColor}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,20"/>

                        <Border Width="50" Height="2" Background="{StaticResource LightGreenColor}" 
                                HorizontalAlignment="Left" Margin="0,0,0,15"/>

                        <Border Background="{StaticResource LightBeigeColor}" 
                                CornerRadius="12" 
                                Padding="20,15"
                                Margin="0,0,0,15">

                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="🏭" FontSize="14" Margin="0,0,12,0"/>
                                    <TextBlock Text="Учет времени работы и простоев оборудования" 
                                               FontSize="12" Foreground="{StaticResource TextColor}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="⚙️" FontSize="14" Margin="0,0,12,0"/>
                                    <TextBlock Text="Автоматический расчет показателей OEE" 
                                               FontSize="12" Foreground="{StaticResource TextColor}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="📅" FontSize="14" Margin="0,0,12,0"/>
                                    <TextBlock Text="Ведение истории по сменам и периодам" 
                                               FontSize="12" Foreground="{StaticResource TextColor}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="📈" FontSize="14" Margin="0,0,12,0"/>
                                    <TextBlock Text="Формирование аналитических отчетов" 
                                               FontSize="12" Foreground="{StaticResource TextColor}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="👥" FontSize="14" Margin="0,0,12,0"/>
                                    <TextBlock Text="Разграничение прав доступа пользователей" 
                                               FontSize="12" Foreground="{StaticResource TextColor}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Border VerticalAlignment="Bottom" 
                Background="{StaticResource DarkBeigeColor}" 
                Opacity="0.5"
                Height="28">
            <TextBlock Text="© 2026 ООО «ЭКО-Золопродукт инвест» | Система учета работы оборудования" 
                       FontSize="9" 
                       Foreground="{StaticResource TextColor}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>