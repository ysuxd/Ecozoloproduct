<Window x:Class="WpfApp2.EfficiencyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Анализ эффективности оборудования" 
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F5F0E8">

    <Window.Resources>
        <SolidColorBrush x:Key="BeigeColor" Color="#F5F0E8"/>
        <SolidColorBrush x:Key="DarkBeigeColor" Color="#E8DCC8"/>
        <SolidColorBrush x:Key="LightBeigeColor" Color="#FAF6EF"/>
        <SolidColorBrush x:Key="GreenColor" Color="#5A8F4C"/>
        <SolidColorBrush x:Key="DarkGreenColor" Color="#3D6B2E"/>
        <SolidColorBrush x:Key="LightGreenColor" Color="#7BAF6A"/>
        <SolidColorBrush x:Key="WhiteColor" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextColor" Color="#4A3728"/>

        <Style x:Key="GreenButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource GreenColor}"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteColor}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource LightGreenColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource DarkGreenColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BeigeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource DarkBeigeColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource GreenColor}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                BorderThickness="1"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BeigeColor}"/>
                                <Setter Property="Foreground" Value="{StaticResource DarkGreenColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ExitButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E74C3C"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteColor}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C0392B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#A93226"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource WhiteColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DarkBeigeColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{StaticResource GreenColor}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource WhiteColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DarkBeigeColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource WhiteColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource BeigeColor}"/>
            <Setter Property="RowBackground" Value="{StaticResource WhiteColor}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="BorderBrush" Value="{StaticResource DarkBeigeColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource GreenColor}"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteColor}"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{StaticResource LightGreenColor}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="5,0,5,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="PageHeaderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource GreenColor}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20" Background="{StaticResource BeigeColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PageHeaderStyle}">
            <TextBlock Text="📊 АНАЛИЗ ЭФФЕКТИВНОСТИ ОБОРУДОВАНИЯ 📊" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="{StaticResource WhiteColor}" 
                       HorizontalAlignment="Center" 
                       Margin="20,15"
                       FontFamily="Segoe UI"/>
        </Border>

        <!-- Фильтры -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15"
                BorderBrush="{StaticResource DarkBeigeColor}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Первая строка фильтров -->
                <WrapPanel Grid.Row="0" Margin="0,5,0,10" VerticalAlignment="Center">
                    <TextBlock Text="Оборудование:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                    <ComboBox x:Name="EquipmentComboBox" Width="200" Height="38" 
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              Margin="5,5,15,5"/>

                    <TextBlock Text="Смена:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                    <ComboBox x:Name="ShiftComboBox" Width="250" Height="38" 
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              Margin="5,5,15,5"/>
                </WrapPanel>

                <!-- Вторая строка фильтров - период дат -->
                <!-- Вторая строка фильтров - период дат -->
                <WrapPanel Grid.Row="1" Margin="0,5,0,5" VerticalAlignment="Center">
                    <TextBlock Text="Период:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" FontWeight="Bold"/>

                    <TextBlock Text="от:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    <DatePicker x:Name="StartDatePicker" Width="120" Height="38" Margin="5,5,5,5"/>

                    <TextBlock Text="до:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                    <DatePicker x:Name="EndDatePicker" Width="120" Height="38" Margin="5,5,15,5"/>

                    <Button x:Name="CalculateButton" Content="📊 Рассчитать" Style="{StaticResource GreenButtonStyle}" Click="CalculateButton_Click"/>
                    <Button x:Name="CompareButton" Content="📊 Сравнить" Style="{StaticResource GreenButtonStyle}" Click="CompareButton_Click"/>
                    <Button x:Name="TrendButton" Content="📈 Динамика" Style="{StaticResource GreenButtonStyle}" Click="TrendButton_Click"/>
                    <Button x:Name="ExportPdfButton" Content="📄 Экспорт в PDF" Style="{StaticResource GreenButtonStyle}" Click="ExportPdfButton_Click"/>
                    <Button x:Name="RefreshButton" Content="🔄 Сбросить" Style="{StaticResource BeigeButtonStyle}" Click="RefreshButton_Click"/>
                    <Button x:Name="ExitButton" Content="🚪 Выход" Style="{StaticResource ExitButtonStyle}" Click="ExitButton_Click"/>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- Таблица данных -->
        <DataGrid x:Name="EfficiencyDataGrid" Grid.Row="2" 
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False" 
                  CanUserDeleteRows="False"
                  SelectionMode="Single" 
                  SelectionUnit="FullRow"
                  Margin="0,10,0,10"
                  AlternatingRowBackground="{StaticResource BeigeColor}"
                  RowBackground="{StaticResource WhiteColor}"
                  BorderBrush="{StaticResource DarkBeigeColor}"
                  BorderThickness="1"
                  FontSize="13"
                  FontFamily="Segoe UI">

            <DataGrid.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#5A8F4C" Opacity="0.2"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#3D6B2E"/>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Оборудование" Binding="{Binding EquipmentName}" Width="2*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Доступность (A)" Binding="{Binding AvailabilityDisplay}" Width="1.5*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource GreenColor}"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Производительность (P)" Binding="{Binding PerformanceDisplay}" Width="1.5*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource GreenColor}"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Качество (Q)" Binding="{Binding QualityDisplay}" Width="1.5*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource GreenColor}"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="OEE (%)" Binding="{Binding OEEDisplay}" Width="1.5*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource DarkGreenColor}"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="16"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Итоговая панель -->
        <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="15" Margin="0,5,0,0"
                BorderBrush="{StaticResource DarkBeigeColor}" BorderThickness="1">
            <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Общий OEE за период:" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" Margin="10,0"/>
                <TextBlock x:Name="TotalOEETextBlock" FontSize="24" FontWeight="Bold" 
                           Foreground="{StaticResource GreenColor}" VerticalAlignment="Center" Margin="10,0"/>
                <TextBlock Text="%" FontSize="16" FontWeight="Bold" Foreground="{StaticResource GreenColor}" VerticalAlignment="Center"/>
            </WrapPanel>
        </Border>
    </Grid>
</Window>